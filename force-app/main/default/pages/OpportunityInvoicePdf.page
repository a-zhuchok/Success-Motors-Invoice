<apex:page 
    standardController="Opportunity"
    extensions="OpportunityInvoicePdfController"
    renderAs="pdf"
    applyBodyTag="false"
    showHeader="false"
    sidebar="false"
    standardStylesheets="false">

    <table width="100%" cellpadding="0" cellspacing="0" 
           style="background-color:#f2f2f2; border-top:8px solid #f85a23;">
        <tr>
            <td style="padding:10px;">
                <table width="100%">
                    <tr>
                        <td width="70%" valign="top">
                            <table>
                                <tr>
                                    <td width="50" valign="top">
                                        <img src="{!URLFOR($Resource.InvoiceLogo)}" width="40" height="40"/>
                                    </td>
                                    <td valign="top" style="font-family:Arial; font-size:10px;">
                                        <div style="font-size:16px; font-weight:bold; color:#1f3d7a;">
                                            {!orgInfo.Name}
                                        </div>
                                        <div>{!orgInfo.Country}, {!orgInfo.City}, {!orgInfo.Street}</div>
                                        <div style="margin-top:5px;">{!opportunityRecord.Owner.Name}</div>
                                    </td>
                                </tr>
                            </table>
                        </td>

                        <td width="30%" align="center" valign="top" 
                            style="font-family:Arial;">
                            <div style="font-size:26px; color:#696969;">
                                INVOICE
                            </div>

                            <div style="margin-top:5px;">
                                <apex:outputText value="{0,date,dd.MM.yyyy}">
                                    <apex:param value="{!invoiceDate}"/>
                                </apex:outputText>
                                <div style="border-bottom:1px solid #b3b3b3; margin:5px 0;"></div>
                            </div>

                            <div style="margin-top:5px;">
                                {!opportunityRecord.Invoice_Number__c}
                                <div style="border-bottom:1px solid #b3b3b3; margin:5px 0;"></div>
                            </div>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>

    <table width="100%" style="margin-top:20px; font-family:Arial; font-size:10px;">
        <tr>
            <td>
                <div style="font-weight:bold; font-size:12px; color:#1f3d7a;">
                    BILL TO
                </div>
                <div style="border-bottom:1px solid #b3b3b3; margin:5px 0;"></div>

                <div style="margin-top:5px;">{!primaryContactName}</div>
                <div style="margin-top:5px;">{!opportunityRecord.Account.Name}</div>
                <div style="margin-top:5px;">{!primaryContactPhone}</div>
                <div style="margin-top:5px;">{!primaryContactEmail}</div>
            </td>
        </tr>
    </table>

    <table width="100%" cellpadding="0" cellspacing="0" 
           style="margin-top:30px; border-collapse:collapse; font-family:Arial; font-size:9px;">

        <thead>
            <tr>
                <th width="45%" align="center" style="font-weight:bold; background-color:#f85a23; color:#ffffff; border:1px solid #b3b3b3; padding:5px;">
                    PRODUCT NAME
                </th>
                <th width="15%" align="center" style="font-weight:bold; background-color:#f85a23; color:#ffffff; border:1px solid #b3b3b3; padding:5px;">
                    QTY
                </th>
                <th width="20%" align="center" style="font-weight:bold; background-color:#f85a23; color:#ffffff; border:1px solid #b3b3b3; padding:5px;">
                    UNIT PRICE
                </th>
                <th width="20%" align="center" style="font-weight:bold; background-color:#f85a23; color:#ffffff; border:1px solid #b3b3b3; padding:5px;">
                    TOTAL
                </th>
            </tr>
        </thead>

        <tbody>
            <apex:repeat value="{!lineItems}" var="item">
                <tr>
                    <td style="border:1px solid #c9c9c9; padding:4px;">
                        {!item.PricebookEntry.Name}
                    </td>

                    <td align="center" style="border:1px solid #c9c9c9; padding:4px;">
                        <apex:outputText value="{0,number,#,##0.##}">
                            <apex:param value="{!item.Quantity}" />
                        </apex:outputText>
                    </td>

                    <td align="right" style="border:1px solid #c9c9c9; padding:4px;">
                        <apex:outputText value="{0,number,###,##0.00}">
                            <apex:param value="{!item.UnitPrice}" />
                        </apex:outputText>
                    </td>

                    <td align="right" style="border:1px solid #c9c9c9; padding:4px;">
                        <apex:outputText value="{0,number,###,##0.00}">
                            <apex:param value="{!item.TotalPrice}" />
                        </apex:outputText>
                    </td>
                </tr>
            </apex:repeat>

            <tr>
                <td colspan="4" align="right" style="padding-top:10px;">

                    <span style="font-size:18px; font-weight:bold; color:#1f3d7a;">
                        Balance Due
                    </span>

                    <span style="font-size:22px; font-weight:bold; border:1px solid #c9c9c9; padding:6px 10px; background-color:#f6dcdc;">
                        <apex:outputText value="{0,number,$###,##0.00}">
                            <apex:param value="{!grandTotal}" />
                        </apex:outputText>
                    </span>

                </td>
            </tr>
        </tbody>
    </table>

    <table width="100%" cellpadding="0" cellspacing="0" 
           style="margin-top:40px; background-color:#f85a23;">
        <tr>
            <td align="center" 
                style="color:#ffffff; padding:6px; font-weight:bold; font-family:Arial;">
                {!orgInfo.Name}
            </td>
        </tr>
    </table>

</apex:page>
